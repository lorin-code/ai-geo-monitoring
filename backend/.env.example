# Server
PORT=3002
NODE_ENV=development

# Database
# Relative paths are resolved from the backend process working directory.
DB_STORAGE=database.sqlite

# Security
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Default admin bootstrap
# Change this before first production startup.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Membership defaults
DEFAULT_MEMBERSHIP_LEVEL=free
QUOTA_LOW_THRESHOLD=0.2

# AI platform keys
DOUBAO_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=doubao-1-5-pro-32k-250115

DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

KIMI_API_KEY=
KIMI_API_URL=

QIANWEN_API_KEY=
QIANWEN_API_URL=

# Optional proxy
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# PROXY_URL=http://proxy.example.com:8080

